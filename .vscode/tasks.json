{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: compile",
      "type": "shell",
      "command": "npm run compile",
      "options": { "cwd": "${workspaceFolder}/apps/prism-vscode" },
      "group": "build",
      "problemMatcher": "$esbuild-watch",
      "isBackground": false
    },
    {
      "label": "npm: watch",
      "type": "shell",
      "command": "npm run watch",
      "options": { "cwd": "${workspaceFolder}/apps/prism-vscode" },
      "group": "build",
      "problemMatcher": "$esbuild-watch",
      "isBackground": true
    }
  ]
}
