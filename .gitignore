# Dependencies
node_modules/

# Reference files
.prism/shared/ref/

# Build artifacts
bin/
cmd/prism-cli/bin/
# Tauri installer resources (populated at CI time)
cmd/prism-installer/src-tauri/resources/
cmd/prism-cli/prism-cli
cmd/prism-cli/prism-cli.exe
*.exe

# Go build cache (go.sum is committed for reproducible CI builds)
# Prism local artifacts (not committed)
.prism/local/

# Dev-only MCP config — not shipped with the plugin
.mcp.json

# Visual regression diffs (ephemeral, regenerated on each run)
.prism/shared/validation/diffs/

# Graphify generated graphs (regenerate with: graphify update <path>)
graphify-out/
**/graphify-out/

# Generated community skills (regenerate with: python scripts/prism-sync-skills.py)
skills/generated/

# Local scratch: logs, archives, dry-run output (never committed)
*.log
*.zip
**/_worker_dryrun/
**/.prism/local/
# Lefthook scaffold (regenerated by `lefthook install`)
lefthook.yml

# VitePress build output + cache (rebuilt by docs:build and the docs-deploy CI)
prism-docs/docs/.vitepress/dist/
prism-docs/docs/.vitepress/cache/

# Superpowers brainstorm session state (local)
.superpowers/

# prism-eval is its own repo (backed up to electron-react-vite-ts-starter#prism-eval-app)
# — kept out of the plugin tree: an orphan gitlink (no .gitmodules) breaks marketplace content sync
prism-eval/
