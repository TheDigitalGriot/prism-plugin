{
  "name": "prism",
  "displayName": "Prism",
  "description": "Prism 4-phase development workflow: Research → Plan → Implement → Validate",
  "version": "2.4.5",
  "publisher": "prism",
  "private": true,
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "claude",
    "workflow",
    "spectrum",
    "prism"
  ],
  "activationEvents": [
    "onView:prism.sidebar",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prism",
          "title": "Prism",
          "icon": "media/prism-icon.svg"
        }
      ],
      "panel": [
        {
          "id": "prism-panel",
          "title": "Prism",
          "icon": "media/prism-icon.svg"
        }
      ]
    },
    "views": {
      "prism": [
        {
          "type": "webview",
          "id": "prism.sidebar",
          "name": "Prism"
        },
        {
          "id": "prism.research",
          "name": "Research",
          "when": "prism.hasPrismDir"
        },
        {
          "id": "prism.plans",
          "name": "Plans",
          "when": "prism.hasPrismDir"
        },
        {
          "id": "prism.stories",
          "name": "Stories",
          "when": "prism.hasStoriesJson"
        }
      ],
      "prism-panel": [
        {
          "type": "webview",
          "id": "prism.mainView",
          "name": "Prism"
        }
      ]
    },
    "commands": [
      {
        "command": "prism.openSidebar",
        "title": "Open Prism Sidebar",
        "category": "Prism"
      },
      {
        "command": "prism.research",
        "title": "Start Research Phase",
        "category": "Prism"
      },
      {
        "command": "prism.plan",
        "title": "Start Plan Phase",
        "category": "Prism"
      },
      {
        "command": "prism.implement",
        "title": "Start Implement Phase",
        "category": "Prism"
      },
      {
        "command": "prism.validate",
        "title": "Start Validate Phase",
        "category": "Prism"
      },
      {
        "command": "prism.spectrum",
        "title": "Start Spectrum Execution",
        "category": "Prism"
      },
      {
        "command": "prism.initPrism",
        "title": "Initialize .prism/ Directory",
        "category": "Prism"
      },
      {
        "command": "prism.research.open",
        "title": "Open Research Document",
        "category": "Prism"
      },
      {
        "command": "prism.research.delete",
        "title": "Delete Research Document",
        "category": "Prism",
        "icon": "$(trash)"
      },
      {
        "command": "prism.research.refresh",
        "title": "Refresh Research",
        "category": "Prism",
        "icon": "$(refresh)"
      },
      {
        "command": "prism.plans.open",
        "title": "Open Plan",
        "category": "Prism"
      },
      {
        "command": "prism.plans.decompose",
        "title": "Decompose to Stories",
        "category": "Prism"
      },
      {
        "command": "prism.plans.implement",
        "title": "Implement Plan",
        "category": "Prism"
      },
      {
        "command": "prism.plans.delete",
        "title": "Delete Plan",
        "category": "Prism",
        "icon": "$(trash)"
      },
      {
        "command": "prism.plans.refresh",
        "title": "Refresh Plans",
        "category": "Prism",
        "icon": "$(refresh)"
      },
      {
        "command": "prism.stories.execute",
        "title": "Execute Story",
        "category": "Prism"
      },
      {
        "command": "prism.stories.markComplete",
        "title": "Mark Story Complete",
        "category": "Prism"
      },
      {
        "command": "prism.stories.refresh",
        "title": "Refresh Stories",
        "category": "Prism",
        "icon": "$(refresh)"
      },
      {
        "command": "prism.spectrum.start",
        "title": "Start Spectrum Execution",
        "category": "Prism",
        "icon": "$(play)"
      },
      {
        "command": "prism.spectrum.pause",
        "title": "Pause Spectrum",
        "category": "Prism",
        "icon": "$(debug-pause)"
      },
      {
        "command": "prism.spectrum.stop",
        "title": "Stop Spectrum",
        "category": "Prism",
        "icon": "$(debug-stop)"
      },
      {
        "command": "prism.commit",
        "title": "Prism Commit",
        "category": "Prism",
        "icon": "$(git-commit)"
      },
      {
        "command": "prism.decompose",
        "title": "Decompose Plan to Stories",
        "category": "Prism",
        "icon": "$(list-tree)"
      },
      {
        "command": "prism.handoff",
        "title": "Create Handoff Document",
        "category": "Prism",
        "icon": "$(export)"
      },
      {
        "command": "prism.describePR",
        "title": "Generate PR Description",
        "category": "Prism",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "prism.office.show",
        "title": "Show Office",
        "category": "Prism"
      },
      {
        "command": "prism.office.launchAgent",
        "title": "Launch Agent",
        "category": "Prism"
      },
      {
        "command": "prism.office.exportLayout",
        "title": "Export Office Layout",
        "category": "Prism"
      },
      {
        "command": "prism.monitor.runGate",
        "title": "Run Quality Gate",
        "category": "Prism"
      },
      {
        "command": "prism.monitor.runAllGates",
        "title": "Run All Quality Gates",
        "category": "Prism"
      },
      {
        "command": "prism.workspaces.openProject",
        "title": "Open Project",
        "category": "Prism"
      },
      {
        "command": "prism.workspaces.newWorktree",
        "title": "New Worktree",
        "category": "Prism"
      },
      {
        "command": "prism.workspaces.deleteWorktree",
        "title": "Delete Worktree",
        "category": "Prism"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "prism.research.refresh",
          "when": "view == prism.research",
          "group": "navigation"
        },
        {
          "command": "prism.plans.refresh",
          "when": "view == prism.plans",
          "group": "navigation"
        },
        {
          "command": "prism.stories.refresh",
          "when": "view == prism.stories",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "prism.research.open",
          "when": "viewItem == researchDoc",
          "group": "1_open"
        },
        {
          "command": "prism.research.delete",
          "when": "viewItem == researchDoc",
          "group": "9_delete"
        },
        {
          "command": "prism.plans.open",
          "when": "viewItem == planDoc",
          "group": "1_open"
        },
        {
          "command": "prism.plans.decompose",
          "when": "viewItem == planDoc",
          "group": "2_actions"
        },
        {
          "command": "prism.plans.implement",
          "when": "viewItem == planDoc",
          "group": "2_actions"
        },
        {
          "command": "prism.plans.delete",
          "when": "viewItem == planDoc",
          "group": "9_delete"
        },
        {
          "command": "prism.stories.execute",
          "when": "viewItem =~ /^story_pending/ || viewItem =~ /^story_in_progress/",
          "group": "1_actions"
        },
        {
          "command": "prism.stories.markComplete",
          "when": "viewItem =~ /^story_/",
          "group": "1_actions"
        }
      ]
    },
    "keybindings": [
      {
        "command": "prism.research",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "prism.hasPrismDir"
      },
      {
        "command": "prism.plan",
        "key": "ctrl+shift+alt+p",
        "mac": "cmd+shift+alt+p",
        "when": "prism.hasPrismDir"
      },
      {
        "command": "prism.implement",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "prism.hasPrismDir"
      },
      {
        "command": "prism.validate",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "prism.hasPrismDir"
      },
      {
        "command": "prism.spectrum.start",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "prism.hasStoriesJson"
      }
    ],
    "walkthroughs": [
      {
        "id": "prism.gettingStarted",
        "title": "Get Started with Prism",
        "description": "Set up your AI-powered 4-phase development workflow.",
        "steps": [
          {
            "id": "welcome",
            "title": "Welcome to Prism",
            "description": "Prism guides you through Research → Plan → Implement → Validate using Claude AI.\n\n[Open Prism Sidebar](command:prism.openSidebar)",
            "media": {
              "svg": "media/prism-icon.svg",
              "altText": "Prism logo"
            },
            "completionEvents": [
              "onCommand:prism.openSidebar"
            ]
          },
          {
            "id": "init-prism",
            "title": "Set Up .prism/ Directory",
            "description": "Initialize the Prism directory structure in your workspace root to store research, plans, and stories.\n\n[Initialize .prism/](command:prism.initPrism)",
            "media": {
              "svg": "media/prism-icon.svg",
              "altText": "Initialize .prism/"
            },
            "completionEvents": [
              "onCommand:prism.initPrism"
            ]
          },
          {
            "id": "configure-claude",
            "title": "Configure Claude",
            "description": "Prism uses your Claude Max subscription via the Claude CLI. Install it globally with `npm install -g @anthropic-ai/claude-code`, then run `claude login` to authenticate.\n\n[Open Prism Sidebar](command:prism.openSidebar)",
            "media": {
              "svg": "media/prism-icon.svg",
              "altText": "Configure Claude"
            },
            "completionEvents": []
          },
          {
            "id": "first-research",
            "title": "Your First Research",
            "description": "Start the Research phase to document your codebase. Prism spawns parallel AI agents to map your architecture, patterns, and existing code.\n\n[Start Research](command:prism.research)",
            "media": {
              "svg": "media/prism-icon.svg",
              "altText": "Start Research"
            },
            "completionEvents": [
              "onCommand:prism.research"
            ]
          }
        ]
      }
    ],
    "configuration": {
      "title": "Prism",
      "properties": {
        "prism.defaultModel": {
          "type": "string",
          "enum": [
            "opus",
            "sonnet"
          ],
          "default": "sonnet",
          "description": "Default Claude model for implementation"
        },
        "prism.planningModel": {
          "type": "string",
          "enum": [
            "opus",
            "sonnet"
          ],
          "default": "opus",
          "description": "Claude model for research and planning"
        },
        "prism.spectrum.maxIterations": {
          "type": "number",
          "default": 50,
          "description": "Maximum Spectrum iterations before stopping"
        },
        "prism.spectrum.pauseSeconds": {
          "type": "number",
          "default": 2,
          "description": "Pause between Spectrum iterations (seconds)"
        },
        "prism.autoApprove.readFile": {
          "type": "boolean",
          "default": true,
          "description": "Auto-approve file read operations"
        },
        "prism.autoApprove.listFiles": {
          "type": "boolean",
          "default": true,
          "description": "Auto-approve file listing operations"
        },
        "prism.autoApprove.searchFiles": {
          "type": "boolean",
          "default": true,
          "description": "Auto-approve file search operations"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.mjs && npm run build:panel",
    "watch": "npm-run-all -p watch:esbuild watch:webview watch:panel",
    "watch:esbuild": "node esbuild.mjs --watch",
    "watch:webview": "cd webview-ui && npm run dev",
    "watch:panel": "cd webview-panel && npm run dev",
    "build:webview": "cd webview-ui && npm run build",
    "build:panel": "cd webview-panel && npm run build",
    "package": "npm run check-types && npm run build:panel && npm run build:webview && node esbuild.mjs --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "test:unit": "jest"
  },
  "dependencies": {
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.3.0",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "pngjs": "^7.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.5"
  }
}
