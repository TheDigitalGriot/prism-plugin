{
  "productName": "Prism Setup",
  "version": "2.4.6",
  "identifier": "com.thedigitalgriot.prism-setup",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Prism Setup",
        "width": 520,
        "height": 600,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        }
      },
      "minimumSystemVersion": "10.15"
    }
  }
}
