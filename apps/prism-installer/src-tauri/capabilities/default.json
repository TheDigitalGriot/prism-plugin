{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main installer window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-set-title",
    "core:window:allow-start-dragging",
    "os:default",
    "shell:default",
    "dialog:default",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "exec-cmd",
          "cmd": "cmd",
          "args": ["/c", { "validator": ".*" }],
          "sidecar": false
        }
      ]
    }
  ]
}
