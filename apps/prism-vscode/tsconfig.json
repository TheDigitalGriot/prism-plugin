{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./out",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": false,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@prism-core/*": ["../../packages/prism-core/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "webview-ui", "dist", "out"]
}
