{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "paths": {
      "@prism-core/*": ["../../packages/prism-core/src/*", "../prism-vscode/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "webview-ui"]
}
