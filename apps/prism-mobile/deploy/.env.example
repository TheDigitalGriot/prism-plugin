# Griot daemon — environment (copy to Coolify env / .env)
# Bind address inside the container. 0.0.0.0 so Coolify/relay can reach it.
PASEO_LISTEN=0.0.0.0:6767
# Persistent state dir (mount a volume here).
PASEO_HOME=/data
# Where agents check out / operate on your Griot repos (mount a volume here).
PASEO_SOURCE_CHECKOUT_PATH=/workspace
# Dial OUT to the live Cloudflare relay so phones/surfaces can reach this daemon.
PASEO_RELAY_ENABLED=true
# host:port[/path] form — the daemon's parser rejects scheme URLs; TLS auto-derived from :443.
# (PASEO_RELAY_PUBLIC_ENDPOINT intentionally unset — defaults to PASEO_RELAY_ENDPOINT.)
PASEO_RELAY_ENDPOINT=prism.digitalgriot.studio:443/relay
# Host of the pairing landing page baked into offer links (else falls back to app.paseo.sh).
PASEO_APP_BASE_URL=https://prism.digitalgriot.studio
PASEO_NODE_ENV=production
PASEO_LOG_FORMAT=json
PASEO_LOG_LEVEL=info
# Locks DIRECT (:6767) connections; relay pairing is governed by offer-link possession either way.
# Set a strong value; empty/unset = disabled.
PASEO_PASSWORD=
